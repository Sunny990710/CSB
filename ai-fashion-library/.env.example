# Gemini API key — required for the AI agent features
# (image analysis, overdue-email drafting). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY="여기에_본인_API_KEY"

# --- 구글 스프레드시트 정보 불러오기 -------------------------------------
# 기본은 API 키 없이 CSV 내보내기로 읽습니다.
# 시트는 반드시 "링크가 있는 모든 사용자: 뷰어"로 공유되어 있어야 합니다.

# 항상 같은 시트를 쓴다면 ID를 넣어두면 화면에서 주소 입력 없이 바로 불러옵니다.
DEFAULT_SHEET_ID=""
DEFAULT_SHEET_GID="0"

# (선택) 비공개 시트를 API 키로 읽고 싶을 때만 설정.
GOOGLE_SHEETS_API_KEY=""

# Port the server listens on. Render/HF inject this automatically.
PORT=3000

# Optional: point the JSON DB at a writable/persistent folder in production
# (e.g. /data on a Hugging Face Space). Defaults to the project root.
# DATA_DIR=/data
